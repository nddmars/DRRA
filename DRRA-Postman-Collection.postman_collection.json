    {
      "name": "THE SHIELD - Recovery & Isolation",
      "item": [
        {
          "name": "Isolate Resource (VLAN)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resource_id\": \"workstation_001\",\n  \"action\": \"vlan_isolate\",\n  \"reason\": \"test_simulation\",\n  \"preserve_logs\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/shield/isolate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "shield", "isolate"]
            },
            "description": "Isolate an infected resource via VLAN micro-segmentation"
