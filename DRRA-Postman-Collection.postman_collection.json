              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_host\": \"workstation_001\",\n  \"target_host\": \"file_server_01\",\n  \"attack_type\": \"kerberos_delegation\",\n  \"duration_seconds\": 30\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/forge/identity-squat/kerberos-test",
              "host": ["{{base_url}}"],
