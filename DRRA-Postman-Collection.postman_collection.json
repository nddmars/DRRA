    {
      "name": "THE FORGE - Simulation & Testing",
      "item": [
        {
          "name": "Deploy Honeypot",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"First Test Honeypot\",\n  \"payload_type\": \"honeypot\",\n  \"target_path\": \"C:\\\\test\",\n  \"duration_seconds\": 60\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/forge/deploy",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "forge", "deploy"]
            },
            "description": "Deploy a honeypot simulation at specified path"
          },
          "response": []
        },
        {
          "name": "Generate Honeypot Files",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"file_types\": [\"pdf\", \"docx\", \"xlsx\"],\n  \"count\": 50,\n  \"size_mb\": 1.0\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/forge/honeypot/generate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "forge", "honeypot", "generate"]
            },
            "description": "Generate realistic honeypot files (PDFs, documents, spreadsheets)"
          },
          "response": []
        },
